---
import { base } from '@/config'
import { getLangFromLocale } from '@/i18n/lang'
import { ui } from '@/i18n/ui'

interface Props {
  autoOpen?: boolean
}

const { autoOpen = false } = Astro.props
const currentLang = getLangFromLocale(Astro.currentLocale)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}
const pagefindBase = base ? `${base}/pagefind` : '/pagefind'
const isProd = import.meta.env.PROD

function normalizePagefindText(text: string) {
  return text
    .replace(/\{COUNT\}/gi, '[COUNT]')
    .replace(/\{SEARCH_TERM\}/gi, '[SEARCH_TERM]')
}

const pagefindTranslations = {
  placeholder: normalizePagefindText(currentUI.searchPlaceholder ?? '键入开始搜索'),
  search_label: normalizePagefindText(currentUI.search ?? 'Search'),
  clear_search: normalizePagefindText(currentUI.searchClear ?? '清除'),
  zero_results: normalizePagefindText(currentUI.searchNoResults ?? '没有找到相关内容'),
  one_result: normalizePagefindText(currentUI.searchOneResult ?? '[COUNT] 条结果'),
  many_results: normalizePagefindText(currentUI.searchManyResults ?? '[COUNT] 条结果'),
}
const pagefindNotReady = currentUI.searchNotReady ?? '搜索索引未准备好。'
---

<div
  class="search-modal"
  data-search-modal
  data-pagefind-ignore
  aria-hidden="true"
  data-auto-open={autoOpen ? '1' : '0'}
  data-not-ready={pagefindNotReady}
>
  <div class="search-modal__backdrop" data-search-close />
  <div
    class="search-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-label={currentUI.search ?? 'Search'}
  >
    <button class="search-modal__close visually-hidden" type="button" data-search-close>
      ×
    </button>

    <div class="search-modal__content">
      <div id="pagefind-modal" class="pagefind pagefind-modal">
        <div class="pagefind-fallback-ui">
          <input
            id="pagefind-modal-fallback-input"
            class="pagefind-fallback-input"
            type="search"
            placeholder={pagefindTranslations.placeholder}
            disabled
          />
        </div>
      </div>
    </div>
  </div>
</div>

<script
  type="module"
  is:inline
  data-astro-rerun
  define:vars={{ pagefindBase, pagefindTranslations, isProd }}
>
  (function () {
    const modal = document.querySelector('[data-search-modal]')
    if (!modal) return

    const state = globalThis.__searchModalState || {
      bound: false,
      modal: null,
      lastActive: null,
      pagefindReady: false,
      pagefindLoading: null,
      resizeObserver: null,
      pendingResizeFrame: null,
      closeHeightFrame: null,
      closeResetTimer: null,
      lastDialogHeight: 0,
      pagefindBase,
      pagefindTranslations,
      isProd,
      notReadyText: '',
      autoOpen: false,
      setOpen: null,
      ensurePagefind: null,
      focusInput: null,
      openModal: null,
      closeModal: null,
      handleClick: null,
      handleKeydown: null,
      handleSearchOpen: null,
      handleSearchIntent: null,
      syncDialogHeight: null,
      scheduleDialogResize: null,
      getCollapsedDialogHeight: null,
      cancelPendingClose: null,
      getFocusableElements: null,
      handleBeforeSwap: null,
    }

    const previousModal = state.modal
    state.modal = modal
    state.pagefindBase = pagefindBase
    state.pagefindTranslations = pagefindTranslations
    state.isProd = isProd
    state.notReadyText = modal.getAttribute('data-not-ready') || 'Search index is not ready.'
    state.autoOpen = modal.getAttribute('data-auto-open') === '1'

    if (previousModal && previousModal !== modal) {
      state.pagefindReady = false
      state.pagefindLoading = null
      if (state.resizeObserver) {
        state.resizeObserver.disconnect()
        state.resizeObserver = null
      }
    }

    globalThis.__searchModalState = state

    const getModal = () => state.modal

    if (!state.bound) {
      state.setOpen = (nextOpen) => {
        const modal = getModal()
        if (!modal) return
        modal.dataset.open = nextOpen ? '1' : '0'
        modal.setAttribute('aria-hidden', nextOpen ? 'false' : 'true')
        document.documentElement.classList.toggle('search-modal-open', nextOpen)
      }

      state.ensurePagefind = async () => {
        if (!state.isProd || state.pagefindReady) return
        if (state.pagefindLoading) return state.pagefindLoading

        const modal = getModal()
        if (!modal) return
        const container = modal.querySelector('#pagefind-modal')
        if (!container) return

        const fallbackMarkup = container.innerHTML

        state.pagefindLoading = (async () => {
          try {
            let link = document.querySelector('link[data-pagefind-ui]')
            if (!link) {
              link = document.createElement('link')
              link.rel = 'stylesheet'
              link.href = `${state.pagefindBase}/pagefind-ui.css`
              link.dataset.pagefindUi = '1'
              document.head.appendChild(link)
            }

            await import(`${state.pagefindBase}/pagefind-ui.js`)

            const { PagefindUI } = globalThis
            if (!PagefindUI) throw new Error('PagefindUI is not available on globalThis')

            container.innerHTML = ''
            void new PagefindUI({
              element: '#pagefind-modal',
              showSubResults: true,
              debounceTimeoutMs: 320,
              excerptLength: 18,
              resetStyles: false,
              translations: state.pagefindTranslations,
            })
            state.pagefindReady = true
          }
          catch (error) {
            if (!container.innerHTML) {
              container.innerHTML = fallbackMarkup || `<p class="pagefind-fallback">${state.notReadyText}</p>`
            }
            console.warn('[Pagefind] Failed to load search assets:', error)
          }
          finally {
            if (!state.pagefindReady) {
              state.pagefindLoading = null
            }
          }
        })()

        return state.pagefindLoading
      }

      state.focusInput = () => {
        const modal = getModal()
        if (!modal) return
        const input =
          modal.querySelector('.pagefind-ui__search-input') ||
          modal.querySelector('.pagefind-fallback-input')
        if (input) input.focus()
      }

      state.syncDialogHeight = () => {
        const modal = getModal()
        if (!modal || modal.dataset.open !== '1') return
        const dialog = modal.querySelector('.search-modal__dialog')
        const innerContainer = modal.querySelector('#pagefind-modal')
        if (!dialog || !innerContainer) return

        const modalStyle = getComputedStyle(modal)
        const paddingTop = Number.parseFloat(modalStyle.paddingTop) || 0
        const paddingBottom = Number.parseFloat(modalStyle.paddingBottom) || 0
        const maxH = Math.max(0, modal.clientHeight - paddingTop - paddingBottom)
        const targetH = Math.min(innerContainer.scrollHeight + 2, maxH)
        if (Math.abs(targetH - state.lastDialogHeight) < 1) return

        state.lastDialogHeight = targetH
        dialog.style.height = `${targetH}px`
      }

      state.scheduleDialogResize = () => {
        if (state.pendingResizeFrame !== null) return
        state.pendingResizeFrame = requestAnimationFrame(() => {
          state.pendingResizeFrame = null
          state.syncDialogHeight()
        })
      }

      state.getCollapsedDialogHeight = () => {
        const modal = getModal()
        if (!modal) return 0
        const input =
          modal.querySelector('.pagefind-ui__search-input') ||
          modal.querySelector('.pagefind-fallback-input')
        if (input instanceof HTMLElement) {
          return Math.ceil(input.getBoundingClientRect().height)
        }

        return window.matchMedia('(max-width: 767px)').matches ? 54 : 61
      }

      state.cancelPendingClose = () => {
        const modal = getModal()
        if (!modal) return

        if (state.closeHeightFrame !== null) {
          cancelAnimationFrame(state.closeHeightFrame)
          state.closeHeightFrame = null
        }

        if (state.closeResetTimer !== null) {
          clearTimeout(state.closeResetTimer)
          state.closeResetTimer = null
        }

        delete modal.dataset.closing
      }

      state.getFocusableElements = () => {
        const modal = getModal()
        if (!modal) return []

        return Array.from(
          modal.querySelectorAll(
            'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])',
          ),
        ).filter((element) => {
          if (!(element instanceof HTMLElement)) return false
          if (element.closest('[aria-hidden="true"]')) return false
          return element.offsetParent !== null || element === document.activeElement
        })
      }

      state.openModal = async () => {
        const modal = getModal()
        if (!modal) return
        if (modal.dataset.open === '1' && modal.dataset.closing !== '1') return
        state.lastActive = document.activeElement
        state.cancelPendingClose()

        state.setOpen(true)

        // === 核心动画逻辑：开启 ResizeObserver ===
        const dialog = modal.querySelector('.search-modal__dialog')
        const innerContainer = modal.querySelector('#pagefind-modal')

        if (dialog && innerContainer && typeof ResizeObserver !== 'undefined') {
          if (state.resizeObserver) {
            state.resizeObserver.disconnect()
          }
          state.resizeObserver = new ResizeObserver(() => {
            if (modal.dataset.open !== '1') return
            state.scheduleDialogResize()
          })
          // 开始监听内容高度
          state.resizeObserver.observe(innerContainer)
        }
        state.scheduleDialogResize()

        await state.ensurePagefind()
        state.scheduleDialogResize()
        requestAnimationFrame(() => state.focusInput())
      }

      state.closeModal = () => {
        const modal = getModal()
        if (!modal) return
        if (modal.dataset.open !== '1') return
        const dialog = modal.querySelector('.search-modal__dialog')
        const currentHeight = dialog instanceof HTMLElement
          ? Math.max(Math.ceil(dialog.getBoundingClientRect().height), state.lastDialogHeight)
          : 0
        const collapsedHeight = state.getCollapsedDialogHeight()

        if (dialog instanceof HTMLElement && currentHeight > 0) {
          dialog.style.height = `${currentHeight}px`
          state.lastDialogHeight = currentHeight
        }

        if (state.resizeObserver) {
          state.resizeObserver.disconnect()
          state.resizeObserver = null
        }
        if (state.pendingResizeFrame !== null) {
          cancelAnimationFrame(state.pendingResizeFrame)
          state.pendingResizeFrame = null
        }

        modal.dataset.closing = '1'
        state.setOpen(false)

        state.closeHeightFrame = requestAnimationFrame(() => {
          state.closeHeightFrame = null
          if (dialog instanceof HTMLElement && collapsedHeight > 0) {
            dialog.style.height = `${collapsedHeight}px`
          }
        })

        const closeDuration = window.matchMedia('(max-width: 767px)').matches ? 380 : 360
        state.closeResetTimer = window.setTimeout(() => {
          state.closeResetTimer = null
          delete modal.dataset.closing
          if (dialog instanceof HTMLElement) {
            dialog.style.height = ''
          }
          state.lastDialogHeight = 0

          if (state.lastActive && typeof state.lastActive.focus === 'function') {
            state.lastActive.focus()
          }
        }, closeDuration + 32)
      }

      state.handleClick = (event) => {
        const target = event.target
        if (!(target instanceof Element)) return

        const trigger = target.closest('[data-search-open]')
        if (trigger) {
          event.preventDefault()
          void state.openModal()
          return
        }

        if (target.closest('[data-search-close]')) {
          state.closeModal()
        }
      }

      state.handleKeydown = (event) => {
        const modal = getModal()
        if (!modal || modal.dataset.open !== '1') return

        if (event.key === 'Escape') {
          state.closeModal()
          return
        }

        if (event.key !== 'Tab') return

        const focusableElements = state.getFocusableElements()
        if (focusableElements.length === 0) {
          event.preventDefault()
          return
        }

        const firstElement = focusableElements[0]
        const lastElement = focusableElements[focusableElements.length - 1]
        const activeElement = document.activeElement

        if (event.shiftKey && activeElement === firstElement) {
          event.preventDefault()
          lastElement.focus()
          return
        }

        if (!event.shiftKey && activeElement === lastElement) {
          event.preventDefault()
          firstElement.focus()
        }
      }

      state.handleSearchOpen = () => void state.openModal()
      state.handleSearchIntent = (event) => {
        const target = event.target
        if (!(target instanceof Element)) return
        if (!target.closest('[data-search-open]')) return

        document.removeEventListener('pointerover', state.handleSearchIntent)
        document.removeEventListener('focusin', state.handleSearchIntent)
        void state.ensurePagefind()
      }

      state.handleBeforeSwap = () => {
        state.cancelPendingClose()

        if (state.resizeObserver) {
          state.resizeObserver.disconnect()
          state.resizeObserver = null
        }

        if (state.pendingResizeFrame !== null) {
          cancelAnimationFrame(state.pendingResizeFrame)
          state.pendingResizeFrame = null
        }

        const modal = getModal()
        const dialog = modal?.querySelector('.search-modal__dialog')
        if (dialog instanceof HTMLElement) {
          dialog.style.height = ''
        }

        if (modal) {
          modal.dataset.open = '0'
          modal.setAttribute('aria-hidden', 'true')
          delete modal.dataset.closing
        }

        document.documentElement.classList.remove('search-modal-open')
        state.lastDialogHeight = 0
      }

      document.addEventListener('click', state.handleClick)
      document.addEventListener('keydown', state.handleKeydown)
      document.addEventListener('search-modal-open', state.handleSearchOpen)
      document.addEventListener('pointerover', state.handleSearchIntent, { passive: true })
      document.addEventListener('focusin', state.handleSearchIntent)
      document.addEventListener('astro:before-swap', state.handleBeforeSwap)
      window.addEventListener('resize', state.scheduleDialogResize, { passive: true })

      state.bound = true
    }

    if (state.autoOpen) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => void state.openModal(), { once: true })
      } else {
        void state.openModal()
      }
    }
  })()
</script>

<style is:global>
  /* ========================================================
     1. 全局遮罩与位置
     ======================================================== */
  .search-modal {
    --search-modal-v-pad: clamp(1rem, 4.8vh, 3rem);
    --search-modal-bottom-pad: max(0.875rem, calc(0.875rem + env(safe-area-inset-bottom)));
    --search-modal-rest-shift: clamp(-1.4rem, -2.8vh, -0.8rem);
    --search-modal-open-duration: var(--motion-slow, 300ms);
    --search-modal-close-duration: 360ms;
    --search-modal-close-duration-mobile: 380ms;
    --search-modal-bg: oklch(var(--un-preset-theme-colors-background) / 0.94);
    --search-modal-text: oklch(var(--un-preset-theme-colors-primary) / 0.96);
    --search-modal-muted: oklch(var(--un-preset-theme-colors-secondary) / 0.82);
    --search-modal-border: oklch(var(--un-preset-theme-colors-secondary) / 0.3);
    --search-modal-border-active: oklch(var(--un-preset-theme-colors-primary) / 0.45);
    --search-modal-hover: oklch(var(--un-preset-theme-colors-secondary) / 0.1);
    --search-modal-tag-bg: oklch(var(--un-preset-theme-colors-secondary) / 0.14);
    --search-modal-tag-text: oklch(var(--un-preset-theme-colors-primary) / 0.74);
    --search-modal-mark: oklch(var(--un-preset-theme-colors-primary));
    --search-modal-backdrop: rgba(15, 23, 42, 0.24);
    --search-modal-search-icon: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="rgba(31,41,55,0.55)" stroke-width="1.8"><circle cx="9" cy="9" r="5.5" /><path d="M13 13l4 4" /></svg>');
    position: fixed;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--search-modal-v-pad) 0.625rem var(--search-modal-bottom-pad);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--motion-base, 220ms) var(--motion-ease-enter, cubic-bezier(0.16, 1, 0.3, 1));
    z-index: 9999;
  }

  :global(html.dark) .search-modal {
    --search-modal-bg: #1c1e26;
    --search-modal-text: rgba(244, 246, 255, 0.95);
    --search-modal-muted: rgba(219, 223, 232, 0.64);
    --search-modal-border: rgba(59, 130, 246, 0.5);
    --search-modal-border-active: rgba(59, 130, 246, 0.95);
    --search-modal-hover: rgba(255, 255, 255, 0.08);
    --search-modal-tag-bg: rgba(255, 255, 255, 0.12);
    --search-modal-tag-text: rgba(244, 246, 255, 0.82);
    --search-modal-mark: #60a5fa;
    --search-modal-backdrop: rgba(0, 0, 0, 0.42);
    --search-modal-search-icon: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.8"><circle cx="9" cy="9" r="5.5" /><path d="M13 13l4 4" /></svg>');
  }

  .search-modal[data-open='1'] {
    opacity: 1;
    pointer-events: auto;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: var(--search-modal-backdrop);
    backdrop-filter: blur(var(--motion-overlay-blur, 5px));
    -webkit-backdrop-filter: blur(var(--motion-overlay-blur, 5px));
  }

  /* ========================================================
     2. 最外层弹窗：高度动画的承载者
     ======================================================== */
  .search-modal__dialog {
    position: relative;
    width: min(48rem, 100%);
    max-height: calc(100dvh - var(--search-modal-v-pad) - var(--search-modal-bottom-pad));
    background: var(--search-modal-bg);
    border: 1px solid var(--search-modal-border);
    border-radius: 0.8rem;
    box-shadow: 0 10px 34px rgba(0, 0, 0, 0.48);
    padding: 0; 
    z-index: 1;
    contain: layout paint;
    
    /* === 动画核心设定 === */
    height: 3.8rem; /* 初始状态：仅输入框的高度 */
    overflow: hidden; /* 防止内容突围 */
    display: flex; /* 让内部可以正确滚动 */
    flex-direction: column;
    
    /* 高级阻尼动画曲线，带来 Apple 级别的丝滑回弹感 */
    transform: translateY(calc(var(--search-modal-rest-shift) - 8px)) scale(0.985);
    transition: height var(--search-modal-open-duration) var(--motion-ease-enter, cubic-bezier(0.16, 1, 0.3, 1)),
                transform var(--motion-base, 220ms) var(--motion-ease-enter, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow var(--motion-fast, 160ms) ease;
    will-change: transform;
  }

  .search-modal[data-open='1'] .search-modal__dialog {
    transform: translateY(var(--search-modal-rest-shift)) scale(1); /* 打开时位移复原 */
    will-change: height, transform;
  }

  .search-modal[data-closing='1'] {
    transition-duration: var(--search-modal-close-duration);
    transition-timing-function: var(--motion-ease-standard, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .search-modal[data-closing='1'] .search-modal__dialog {
    transition:
      height var(--search-modal-close-duration) var(--motion-ease-standard, cubic-bezier(0.22, 1, 0.36, 1)),
      transform 320ms var(--motion-ease-standard, cubic-bezier(0.22, 1, 0.36, 1)),
      box-shadow var(--motion-fast, 160ms) ease;
  }

  .search-modal__dialog:focus-within {
    box-shadow: 0 0 0 1px var(--search-modal-border-active), 0 10px 40px rgba(0, 0, 0, 0.45);
  }

  /* 当内容超出外框高度限制时，允许滚动 */
  .search-modal__content {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* ========================================================
     3. 输入框：纯透明隐形，高度固定
     ======================================================== */
  .search-modal .pagefind.pagefind-modal .pagefind-ui {
    width: 100%;
    font-family: inherit;
    --pagefind-ui-text: var(--search-modal-text);
    --pagefind-ui-primary: var(--search-modal-text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--search-modal-border);
    --pagefind-ui-tag: var(--search-modal-tag-bg);
  }

  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__form {
    position: relative;
    padding: 0 !important;
    margin: 0 !important;
  }

  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__form::before {
    display: none !important;
  }

  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__search-input,
  .search-modal .pagefind-fallback-input {
    width: 100%;
    height: 3.8rem; /* 与外层初始高度一致 */
    padding: 0 3rem;
    font-size: 1rem;
    color: var(--search-modal-text) !important;
    
    background: transparent !important; 
    border: none !important; 
    box-shadow: none !important;
    outline: none !important;

    background-image: var(--search-modal-search-icon);
    background-repeat: no-repeat;
    background-position: 1.2rem center;
    background-size: 1.1rem;
  }

  /* ========================================================
     输入框右侧的清除按钮 (改成完美的叉号)
     ======================================================== */
  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__search-clear {
    position: absolute !important;
    right: 0.5rem !important; /* 紧贴右侧 */
    top: 0 !important;
    height: 3.8rem !important; /* 强制和输入框等高，不仅居中，还能扩大鼠标点击区域 */
    width: 2.5rem !important;
    padding: 0 !important;
    margin: 0 !important;
    background-color: transparent !important;
    border: none !important;
    
    /* 核心魔法：彻底隐藏 Pagefind 默认生成的“清除”或“Clear”文字 */
    color: transparent !important;
    font-size: 0 !important; 
    cursor: pointer;
    z-index: 10; /* 确保它不会被输入框遮挡 */
  }

  /* 利用伪元素 (::after) 画一个居中的叉号 */
  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__search-clear::after {
    content: '×'; /* 使用标准的乘号字符作为关闭图标 */
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    font-size: 1.6rem; /* 叉号的视觉大小 */
    font-weight: 300; /* 让叉号看起来细致秀气一点 */
    color: var(--search-modal-muted); /* 默认半透明灰色 */
    transition: color 0.2s ease;
  }

  /* 鼠标悬停时，叉号变亮，增加交互感 */
  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__search-clear:hover::after {
    color: var(--search-modal-text);
  }

  /* ========================================================
     4. 结果区域：自然撑开内部容器 (外部会自动追踪动画)
     ======================================================== */
  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__drawer:not(:empty) {
    padding: 0.5rem 0.5rem 1rem 0.5rem;
    border-top: 1px solid var(--search-modal-border);
  }

  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__message {
    padding: 0.5rem 0.5rem 0.5rem 0.8rem;
    font-size: 0.85rem;
    color: var(--search-modal-muted);
  }

  /* ====== 为单个结果项加入由下向上的浮现动画 ====== */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .search-modal .pagefind.pagefind-modal .pagefind-ui .pagefind-ui__result {
