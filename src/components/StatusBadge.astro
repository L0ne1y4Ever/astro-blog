---
import { getPostStatusLabel } from '@/utils/content'

interface Props {
  status?: 'idea' | 'ongoing' | 'paused' | 'completed'
  compact?: boolean
  className?: string
}

const { status, compact = false, className = '' } = Astro.props
const label = getPostStatusLabel(status)

const toneClassMap = {
  idea: 'border-amber-400/18 bg-amber-300/6 text-amber-100/72',
  ongoing: 'border-sky-400/18 bg-sky-300/7 text-sky-100/78',
  paused: 'border-zinc-400/18 bg-zinc-300/7 text-zinc-100/74',
  completed: 'border-emerald-400/18 bg-emerald-300/7 text-emerald-100/76',
} as const

const toneClass = status ? toneClassMap[status] : ''
---

{label && (
  <span
    class:list={[
      'status-badge inline-flex items-center rounded-full border border-solid align-middle leading-none font-navbar',
      compact ? 'px-1.6 py-0.45 text-[0.71rem]' : 'px-2 py-0.55 text-[0.76rem]',
      toneClass,
      className,
    ]}
  >
    {label}
  </span>
)}
