---
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'

const { currentLang, isHome, isPost, isTag, isAbout, isSearch, isArchive, isLinks, getLocalizedPath } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

const isPostActive = isHome || isPost
const isTagActive = isTag
const isAboutActive = isAbout
const isSearchActive = isSearch
const isArchiveActive = isArchive
const isLinksActive = isLinks
const isMoreActive = isSearchActive || isArchiveActive || isLinksActive

function getNavItemClass(isActive: boolean) {
  return isActive
    ? 'highlight-static c-primary font-bold after:bottom-0.7em nav-more-highlight'
    : 'highlight-hover transition-[colors,font-weight] after:bottom-0.7em hover:(c-primary font-bold) nav-more-highlight'
}

function getNavMoreItemClass(isActive: boolean) {
  return isActive
    ? 'highlight-static c-primary font-bold after:bottom-0.7em nav-more-highlight'
    : 'highlight-hover transition-[colors,font-weight] after:bottom-0.7em hover:(c-primary font-bold) nav-more-highlight'
}

function getNavMoreToggleClass(isActive: boolean) {
  return isActive
    ? 'highlight-static c-primary font-bold after:bottom-0.7em nav-more-highlight'
    : 'highlight-hover transition-[colors,font-weight] after:bottom-0.7em hover:(c-primary font-bold) nav-more-highlight'
}

const navItems = [
  {
    href: '/',
    label: currentUI.posts,
    className: getNavItemClass(isPostActive),
  },
  {
    href: '/tags/',
    label: currentUI.tags,
    className: getNavItemClass(isTagActive),
  },
  {
    href: '/about/',
    label: currentUI.about,
    className: getNavItemClass(isAboutActive),
  },
]

const moreItems = [
  {
    href: '/search/',
    label: currentUI.search,
    className: getNavMoreItemClass(isSearchActive),
    type: 'search',
  },
  {
    href: '/archive/',
    label: currentUI.archive,
    className: getNavMoreItemClass(isArchiveActive),
  },
  {
    href: '/links/',
    label: currentUI.links,
    className: getNavMoreItemClass(isLinksActive),
  },
]
---

<nav
  aria-label="Site Navigation"
  data-nav-open={isMoreActive ? '1' : '0'}
  class:list={[
    'site-nav mb-10.5 text-3.6 font-semibold leading-2.45em font-navbar md:text-4 cjk:tracking-wide',
    isPost ? 'site-nav--post' : '',
  ]}
>
  <ul class="nav-list">
    {navItems.map(item => (
      <li class="nav-primary-item">
        <a
          href={getLocalizedPath(item.href)}
          class={item.className}
        >
          {item.label}
        </a>
      </li>
    ))}
    <li>
      <div
        class="nav-more-shell"
        aria-hidden="false"
      >
        <button
          type="button"
          class="nav-more-toggle cursor-pointer select-none"
          aria-expanded={isMoreActive ? 'true' : 'false'}
          data-nav-more-trigger
        >
          <span class={getNavMoreToggleClass(isMoreActive)}>
            {currentUI.more}
          </span>
        </button>
        <div class="nav-more-panel" aria-hidden={isMoreActive ? 'false' : 'true'}>
          <ul class="nav-more-list">
            {moreItems.map((item, index) => (
              <li style={`--nav-item-index:${index};`}>
                {item.type === 'search'
                  ? (
                      <button
                        type="button"
                        data-search-open
                        class="nav-search-button"
                      >
                        <span class={item.className}>
                          {item.label}
                        </span>
                      </button>
                    )
                  : (
                      <a
                        href={getLocalizedPath(item.href)}
                        class="nav-more-link"
                      >
                        <span class={item.className}>
                          {item.label}
                        </span>
                      </a>
                    )}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </li>
  </ul>
</nav>

<script is:inline data-astro-rerun>
  (function () {
    function initNavMoreToggle() {
      const nav = document.querySelector('nav[aria-label="Site Navigation"]')
      if (!nav || nav.dataset.navBound === '1') return

      const trigger = nav.querySelector('[data-nav-more-trigger]')
      const panel = nav.querySelector('.nav-more-panel')
      if (!(trigger instanceof HTMLElement) || !(panel instanceof HTMLElement)) return

      let isOpen = nav.dataset.navOpen === '1'

      const setOpen = (nextOpen) => {
        isOpen = nextOpen
        nav.dataset.navOpen = nextOpen ? '1' : '0'
        trigger.setAttribute('aria-expanded', nextOpen ? 'true' : 'false')
        panel.setAttribute('aria-hidden', nextOpen ? 'false' : 'true')
      }

      const controller = new AbortController()

      trigger.addEventListener('click', () => {
        setOpen(!isOpen)
      }, { signal: controller.signal })

      document.addEventListener('keydown', (event) => {
        if (!isOpen || event.key !== 'Escape') return
        setOpen(false)
        trigger.focus()
      }, { signal: controller.signal })

      setOpen(isOpen)
      nav.dataset.navBound = '1'
      nav.__navCleanup = () => {
        controller.abort()
        delete nav.dataset.navBound
        delete nav.__navCleanup
      }
    }

    function cleanupNavMoreToggle() {
      document.querySelectorAll('nav[aria-label="Site Navigation"]').forEach((nav) => {
        nav.__navCleanup?.()
      })
    }

    const navLifecycleState = globalThis.__navMoreLifecycleState || { bound: false }

    if (!navLifecycleState.bound) {
      document.addEventListener('astro:page-load', initNavMoreToggle)
      document.addEventListener('astro:before-swap', cleanupNavMoreToggle)
      navLifecycleState.bound = true
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNavMoreToggle, { once: true })
    }
    else {
      initNavMoreToggle()
    }

    globalThis.__navMoreLifecycleState = navLifecycleState
  })()
</script>

<style>
  :root {
    --nav-motion-easing: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 767px) {
    nav[aria-label='Site Navigation'] {
      position: relative;
      block-size: 9.65rem;
      inline-size: fit-content;
      max-width: 100%;
    }

    .nav-list {
      width: max-content;
      max-width: 100%;
    }
  }

  .site-nav--post {
    display: none;
  }

  @media (min-width: 1024px) {
    .site-nav {
      position: fixed;
      right: max(5rem, calc(50vw - 35rem));
      bottom: min(9.04rem + 3.85vw, 12.5rem);
      width: 14rem;
    }

    .site-nav--post {
      display: block;
    }
  }

  .nav-primary-item {
    max-height: 3.2em;
    opacity: 1;
    transform: translateY(0);
    overflow: hidden;
    transition:
      max-height 220ms var(--nav-motion-easing),
      opacity 180ms var(--nav-motion-easing),
      transform 240ms var(--nav-motion-easing);
  }

  nav[data-nav-open='1'] .nav-primary-item {
    max-height: 0;
    opacity: 0;
    transform: translateY(-0.35em);
    pointer-events: none;
  }

  .nav-more-toggle {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    text-align: left;
  }

  .nav-more-toggle > span {
    display: inline-block;
  }

  nav[data-nav-open='1'] .nav-more-toggle > span {
    color: oklch(var(--un-preset-theme-colors-primary));
    font-weight: 700;
  }

  .nav-more-highlight::after {
    background-color: oklch(0.74 0.09 235 / 0.42);
  }

  .nav-list > li > a.highlight-static::after,
  .nav-list > li > a.highlight-hover::after,
  .nav-more-list span.highlight-static::after,
  .nav-more-list span.highlight-hover::after,
  .nav-more-toggle > span.highlight-static::after,
  .nav-more-toggle > span.highlight-hover::after {
    left: -0.26em;
    width: calc(100% + 0.76em);
  }

  .nav-more-panel {
    display: grid;
    grid-template-rows: 0fr;
    pointer-events: none;
    transition: grid-template-rows var(--motion-base, 220ms) var(--nav-motion-easing);
  }

  nav[data-nav-open='1'] .nav-more-panel {
    grid-template-rows: 1fr;
    pointer-events: auto;
  }

  .nav-more-panel > .nav-more-list {
    min-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(-0.28em);
    transition:
      opacity var(--motion-fast, 160ms) var(--nav-motion-easing),
      transform var(--motion-base, 220ms) var(--nav-motion-easing);
  }

  nav[data-nav-open='1'] .nav-more-panel > .nav-more-list {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-more-list li {
    opacity: 0;
    transform: translateY(-0.24em);
    transition:
      opacity var(--motion-fast, 160ms) var(--nav-motion-easing),
      transform var(--motion-base, 220ms) var(--nav-motion-easing);
  }

  nav[data-nav-open='1'] .nav-more-list li {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--nav-item-index, 0) * 18ms + 12ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-primary-item,
    .nav-more-panel,
    .nav-more-panel > .nav-more-list,
    .nav-more-list li {
      transition: none;
    }
  }

  .nav-search-button {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
  }

  .nav-more-link {
    color: inherit;
    text-decoration: none;
  }

  .nav-more-list li,
  .nav-more-list a,
  .nav-more-list button {
    display: block;
    width: 100%;
    text-align: left;
  }

  .nav-more-list span.highlight-static,
  .nav-more-list span.highlight-hover {
    vertical-align: baseline;
  }

  .nav-more-list {
    margin-top: 0.8rem;
    padding-left: 0;
    list-style: none;
  }

  :global(html.reduce-motion) .nav-primary-item,
  :global(html.reduce-motion) .nav-more-panel,
  :global(html.reduce-motion) .nav-more-panel > .nav-more-list,
  :global(html.reduce-motion) .nav-more-list li {
    transition: none;
  }

  .nav-more-list li + li {
    margin-top: 0.82rem !important;
  }

  .nav-more-list a,
  .nav-more-list button {
    line-height: 1.2 !important;
    padding-top: 0.04rem;
    padding-bottom: 0.04rem;
    display: block;
  }

  .nav-more-list span.highlight-static::after,
  .nav-more-list span.highlight-hover::after {
    bottom: 0.08em !important;
  }
</style>
