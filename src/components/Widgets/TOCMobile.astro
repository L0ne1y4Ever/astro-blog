---
import type { TocPanelProps } from '@/components/Widgets/toc-shared'

const {
  filteredHeadings,
  seriesItems,
  currentUI,
  hasToc,
  hasSeries,
} = Astro.props as TocPanelProps

const mobileDefaultTab = hasToc ? 'toc' : 'series'
const mobileDefaultLabel = mobileDefaultTab === 'toc' ? currentUI.toc : currentUI.series
---

<div
  class="toc-mobile-shell"
  data-mobile-toc-shell
  data-open="0"
  data-default-tab={mobileDefaultTab}
  data-active-tab={mobileDefaultTab}
>
  <button
    id="toc-mobile-trigger"
    class="toc-mobile-trigger"
    type="button"
    data-mobile-panel-trigger
    aria-controls="toc-mobile-panel"
    aria-expanded="false"
    aria-label={hasToc && hasSeries ? '打开目录与系列文章' : `打开${mobileDefaultLabel}`}
  >
    <svg
      aria-hidden="true"
      class="toc-mobile-trigger__icon"
      viewBox="0 0 24 24"
      fill="none"
    >
      <rect x="5.25" y="5.95" width="13.5" height="2.05" rx="1.025" fill="currentColor" />
      <rect x="7.75" y="10.975" width="8.5" height="2.05" rx="1.025" fill="currentColor" />
      <rect x="5.25" y="16" width="13.5" height="2.05" rx="1.025" fill="currentColor" />
    </svg>
  </button>

  <div class="toc-mobile-backdrop" aria-hidden="true" data-mobile-backdrop />

  <section
    id="toc-mobile-panel"
    class="toc-mobile-panel"
    data-mobile-panel
    aria-hidden="true"
    inert
  >
    <div class="toc-mobile-panel__header">
      {hasToc && hasSeries
        ? (
            <div class="toc-mobile-tabs" role="tablist" aria-label="目录与系列文章">
              <button
                id="toc-mobile-tab-toc"
                class="toc-mobile-tab"
                type="button"
                data-mobile-tab="toc"
                role="tab"
                aria-controls="toc-mobile-tab-panel-toc"
                aria-selected={mobileDefaultTab === 'toc' ? 'true' : 'false'}
                tabindex={mobileDefaultTab === 'toc' ? '0' : '-1'}
              >
                {currentUI.toc}
              </button>
              <button
                id="toc-mobile-tab-series"
                class="toc-mobile-tab"
                type="button"
                data-mobile-tab="series"
                role="tab"
                aria-controls="toc-mobile-tab-panel-series"
                aria-selected={mobileDefaultTab === 'series' ? 'true' : 'false'}
                tabindex={mobileDefaultTab === 'series' ? '0' : '-1'}
              >
                {currentUI.series}
              </button>
            </div>
          )
        : <h2 class="toc-mobile-panel__title">{mobileDefaultLabel}</h2>}

      <button
        class="toc-mobile-panel__close"
        type="button"
        data-mobile-panel-close
        aria-label={`关闭${mobileDefaultLabel}`}
      >
        <svg viewBox="0 0 20 20" width="1em" height="1em" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M5.5 5.5 14.5 14.5M14.5 5.5 5.5 14.5" />
        </svg>
      </button>
    </div>

    <div class="toc-mobile-panel__viewport">
      {hasToc && (
        <nav
          id="toc-mobile-tab-panel-toc"
          class="toc-mobile-panel__body toc-mobile-tab-panel"
          data-mobile-tab-panel="toc"
          aria-label="Table of Contents"
          role={hasToc && hasSeries ? 'tabpanel' : undefined}
          aria-labelledby={hasToc && hasSeries ? 'toc-mobile-tab-toc' : undefined}
          aria-hidden={mobileDefaultTab === 'toc' ? 'false' : 'true'}
        >
          <ul class="toc-mobile-links-list">
            {filteredHeadings.map(heading => (
              <li
                class:list={{
                  'ml-0': heading.depth === 2,
                  'ml-4': heading.depth === 3,
                  'ml-8': heading.depth === 4,
                }}
              >
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'toc-mobile-link',
                    { 'no-heti toc-links-h2': heading.depth === 2 },
                    { 'no-heti toc-links-h3': heading.depth === 3 },
                    { 'no-heti toc-links-h4': heading.depth === 4 },
                  ]}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {hasSeries && (
        <div
          id="toc-mobile-tab-panel-series"
          class="toc-mobile-panel__body toc-mobile-tab-panel"
          data-mobile-tab-panel="series"
          role={hasToc && hasSeries ? 'tabpanel' : undefined}
          aria-labelledby={hasToc && hasSeries ? 'toc-mobile-tab-series' : undefined}
          aria-hidden={mobileDefaultTab === 'series' ? 'false' : 'true'}
        >
          <ol class="toc-mobile-series-list">
            {seriesItems.map(item => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'toc-mobile-series-link',
                    item.isCurrent ? 'is-current' : '',
                  ]}
                  aria-current={item.isCurrent ? 'page' : undefined}
                >
                  <span class="toc-mobile-series-name">{item.title}</span>
                  <span class="toc-mobile-series-date font-time">{item.date}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      )}
    </div>
  </section>
</div>

<style>
  @media (min-width: 769px) {
    .toc-mobile-shell {
      display: none;
    }
  }

  .toc-mobile-shell {
    --toc-mobile-panel-width: min(15.7rem, calc(100vw - 2.6rem));
    --toc-mobile-inline-safe: max(0.75rem, calc(env(safe-area-inset-left) + 0.7rem));
    --toc-mobile-left: var(--toc-mobile-inline-safe);
    --toc-mobile-offset-bottom: calc(8.25rem + env(safe-area-inset-bottom));
    --toc-mobile-control-size: 2.56rem;
    --toc-mobile-panel-gap: 0.72rem;
    position: relative;
    z-index: 46;
  }

  .toc-mobile-trigger {
    position: fixed;
    left: var(--toc-mobile-left);
    bottom: var(--toc-mobile-offset-bottom);
    width: var(--toc-mobile-control-size);
    height: var(--toc-mobile-control-size);
    display: inline-grid;
    place-items: center;
    padding: 0;
    border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.12);
    border-radius: 0.95rem;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.09), transparent 56%),
      oklch(var(--un-preset-theme-colors-background) / 0.4);
    color: oklch(0.74 0.16 255 / 0.98);
    box-shadow:
      0 18px 32px oklch(0 0 0 / 0.15),
      inset 0 1px 0 rgb(255 255 255 / 0.13);
    backdrop-filter: blur(20px) saturate(165%);
    -webkit-backdrop-filter: blur(20px) saturate(165%);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 48;
  }

  .toc-mobile-trigger.is-active {
    color: oklch(0.8 0.16 255 / 1);
    border-color: oklch(var(--un-preset-theme-colors-primary) / 0.18);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.12), transparent 58%),
      oklch(var(--un-preset-theme-colors-background) / 0.48);
  }

  .toc-mobile-trigger__icon {
    width: 1.42rem;
    height: 1.42rem;
    display: block;
    filter: drop-shadow(0 0 0.5rem rgb(95 142 255 / 0.22));
  }

  .toc-mobile-backdrop {
    position: fixed;
    inset: 0;
    background: oklch(0 0 0 / 0.14);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 180ms ease, visibility 0s linear 180ms;
    z-index: 44;
  }

  .toc-mobile-panel {
    position: fixed;
    left: var(--toc-mobile-left);
    right: auto;
    bottom: calc(var(--toc-mobile-offset-bottom) + var(--toc-mobile-control-size) + var(--toc-mobile-panel-gap));
    width: var(--toc-mobile-panel-width);
    max-height: min(53vh, 22rem);
    display: flex;
    flex-direction: column;
    padding: 0.66rem;
    border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.12);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.08), transparent 62%),
      oklch(var(--un-preset-theme-colors-background) / 0.58);
    box-shadow:
      0 24px 48px oklch(0 0 0 / 0.18),
      inset 0 1px 0 rgb(255 255 255 / 0.1);
    backdrop-filter: blur(24px) saturate(165%);
    -webkit-backdrop-filter: blur(24px) saturate(165%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.65rem) scale(0.985);
    transition:
      opacity 200ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 220ms;
    z-index: 47;
  }

  .toc-mobile-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
    margin-bottom: 0.52rem;
  }

  .toc-mobile-panel__title {
    margin: 0;
    font-size: 0.94rem;
    font-weight: 650;
    letter-spacing: 0.01em;
    color: oklch(var(--un-preset-theme-colors-primary) / 0.95);
  }

  .toc-mobile-tabs {
    display: inline-flex;
    align-items: center;
    gap: 0.18rem;
    padding: 0.16rem;
    border-radius: 999px;
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.08);
  }

  .toc-mobile-tab {
    min-width: 3.85rem;
    height: 1.9rem;
    padding: 0 0.72rem;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.72);
    font-size: 0.76rem;
    font-weight: 560;
    transition:
      color 160ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .toc-mobile-tab.is-active {
    color: oklch(var(--un-preset-theme-colors-primary) / 0.96);
    background: oklch(var(--un-preset-theme-colors-background) / 0.68);
    box-shadow: 0 1px 10px oklch(0 0 0 / 0.08);
    transform: translateY(-0.02rem);
  }

  .toc-mobile-panel__close {
    width: 1.9rem;
    height: 1.9rem;
    display: inline-grid;
    place-items: center;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.7);
    transition: color 160ms ease, background-color 160ms ease;
  }

  .toc-mobile-panel__viewport {
    position: relative;
    display: grid;
    align-items: start;
    min-height: min(17rem, 38vh);
  }

  .toc-mobile-panel__body {
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: oklch(var(--un-preset-theme-colors-secondary) / 0.16) transparent;
  }

  .toc-mobile-panel__body::-webkit-scrollbar {
    width: 5px;
  }

  .toc-mobile-panel__body::-webkit-scrollbar-thumb {
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.16);
    border-radius: 999px;
  }

  .toc-mobile-links-list,
  .toc-mobile-series-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-mobile-links-list {
    display: grid;
    gap: 0.35rem;
  }

  .toc-mobile-link {
    display: block;
    padding: 0.12rem 0;
    text-decoration: none;
  }

  .toc-mobile-series-list {
    display: grid;
    gap: 0.42rem;
  }

  .toc-mobile-series-link {
    display: grid;
    gap: 0.12rem;
    padding: 0.58rem 0.68rem;
    border-radius: 0.82rem;
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.06);
    text-decoration: none;
    color: oklch(var(--un-preset-theme-colors-secondary) / 0.8);
    transition: color 180ms ease, background-color 180ms ease;
  }

  .toc-mobile-series-link.is-current {
    color: oklch(var(--un-preset-theme-colors-primary) / 0.95);
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.11);
  }

  .toc-mobile-series-name {
    display: block;
    font-size: 0.88rem;
    font-weight: 560;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .toc-mobile-series-date {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    opacity: 0.66;
  }

  .toc-links-h2,
  .toc-links-h3,
  .toc-links-h4 {
    --at-apply: 'text-balance text-sm font-normal no-underline';
    transition: color 0.15s ease-out, font-weight 0.15s ease-out;
  }

  .toc-mobile-tab-panel {
    grid-area: 1 / 1;
    min-height: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.55rem);
    transition:
      opacity 180ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 260ms;
  }

  [data-mobile-toc-shell][data-active-tab='toc'] [data-mobile-tab-panel='toc'],
  [data-mobile-toc-shell][data-active-tab='series'] [data-mobile-tab-panel='series'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    transition-delay: 20ms;
  }

  [data-mobile-toc-shell][data-open='1'] .toc-mobile-backdrop {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s;
  }

  [data-mobile-toc-shell][data-open='1'] .toc-mobile-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(0) scale(1);
    transition-delay: 0s;
  }

  @media (max-width: 768px) {
    .toc-mobile-shell {
      --toc-mobile-panel-width: min(15.7rem, calc(100vw - 2.6rem));
      --toc-mobile-offset-bottom: calc(8.5rem + env(safe-area-inset-bottom));
    }

    .toc-mobile-panel {
      max-height: min(52vh, 21.6rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-mobile-backdrop,
    .toc-mobile-panel,
    .toc-mobile-trigger,
    .toc-mobile-tab,
    .toc-mobile-tab-panel {
      transition: none;
    }
  }

  :global(html.reduce-motion) .toc-mobile-backdrop,
  :global(html.reduce-motion) .toc-mobile-panel,
  :global(html.reduce-motion) .toc-mobile-trigger,
  :global(html.reduce-motion) .toc-mobile-tab,
  :global(html.reduce-motion) .toc-mobile-tab-panel {
    transition: none;
  }
</style>

<script>
type MobileTocShell = HTMLElement & {
  __mobileTocCleanup?: () => void
}

const isMobileViewport = window.matchMedia('(max-width: 768px)')

function initMobileTocPanels() {
  const shell = document.querySelector<MobileTocShell>('[data-mobile-toc-shell]')
  if (!shell || shell.dataset.mobileTocBound === '1') return

  const controller = new AbortController()
  const trigger = shell.querySelector<HTMLElement>('[data-mobile-panel-trigger]')
  const panel = shell.querySelector<HTMLElement>('[data-mobile-panel]')
  const tabs = Array.from(shell.querySelectorAll<HTMLElement>('[data-mobile-tab]'))
  const tabPanels = Array.from(shell.querySelectorAll<HTMLElement>('[data-mobile-tab-panel]'))
  const validTabs = tabPanels
    .map(panelItem => panelItem.dataset.mobileTabPanel)
    .filter((value): value is string => Boolean(value))

  if (!trigger || !panel || validTabs.length === 0) {
    return
  }

  const defaultTab = validTabs.includes(shell.dataset.defaultTab || '')
    ? shell.dataset.defaultTab || validTabs[0]
    : validTabs[0]

  const setActiveTab = (tabName: string = defaultTab) => {
    const nextTab = validTabs.includes(tabName) ? tabName : defaultTab
    shell.dataset.activeTab = nextTab

    tabs.forEach((tab) => {
      const isActive = tab.dataset.mobileTab === nextTab
      tab.classList.toggle('is-active', isActive)
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false')
      tab.tabIndex = isActive ? 0 : -1
    })

    tabPanels.forEach((panelItem) => {
      const isActive = panelItem.dataset.mobileTabPanel === nextTab
      panelItem.setAttribute('aria-hidden', isActive ? 'false' : 'true')
    })
  }

  const setOpen = (nextOpen: boolean) => {
    const isOpen = isMobileViewport.matches && nextOpen
    shell.dataset.open = isOpen ? '1' : '0'
    trigger.classList.toggle('is-active', isOpen)
    trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
    panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true')
    panel.toggleAttribute('inert', !isOpen)
  }

  shell.addEventListener('click', (event) => {
    const target = event.target
    if (!(target instanceof Element)) return

    if (target.closest('[data-mobile-panel-trigger]')) {
      setOpen(shell.dataset.open !== '1')
      return
    }

    const tab = target.closest<HTMLElement>('[data-mobile-tab]')
    if (tab) {
      setActiveTab(tab.dataset.mobileTab || defaultTab)
      return
    }

    if (target.closest('[data-mobile-panel-close]') || target.closest('[data-mobile-backdrop]')) {
      setOpen(false)
      return
    }

    if (target.closest('[data-mobile-panel] a')) {
      setOpen(false)
    }
  }, { signal: controller.signal })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setOpen(false)
    }
  }, { signal: controller.signal })

  isMobileViewport.addEventListener('change', () => {
    if (!isMobileViewport.matches) {
      setOpen(false)
    }
  }, { signal: controller.signal })

  shell.dataset.mobileTocBound = '1'
  shell.__mobileTocCleanup = () => {
    setOpen(false)
    controller.abort()
    delete shell.dataset.mobileTocBound
    delete shell.__mobileTocCleanup
  }

  setActiveTab(defaultTab)
  setOpen(false)
}

function cleanupMobileTocPanels() {
  document.querySelectorAll<MobileTocShell>('[data-mobile-toc-shell]').forEach(shell => shell.__mobileTocCleanup?.())
}

document.addEventListener('astro:page-load', initMobileTocPanels)
document.addEventListener('astro:before-swap', cleanupMobileTocPanels)

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initMobileTocPanels, { once: true })
}
else {
  initMobileTocPanels()
}
</script>
