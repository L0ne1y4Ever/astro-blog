---
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'
import TOCDesktop from '@/components/Widgets/TOCDesktop.astro'
import TOCMobile from '@/components/Widgets/TOCMobile.astro'
import type { TocPanelProps, TocSeriesItem } from '@/components/Widgets/toc-shared'

interface Props {
  headings: TocPanelProps['filteredHeadings']
  seriesItems?: TocSeriesItem[]
}

const { currentLang } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

const { headings = [], seriesItems = [] } = Astro.props as Props
const filteredHeadings = headings.filter(heading => heading.depth >= 2 && heading.depth <= 4)
const hasToc = filteredHeadings.length > 0
const hasSeries = seriesItems.length > 1
---

{(hasToc || hasSeries) && (
  <>
    <TOCMobile
      {filteredHeadings}
      seriesItems={seriesItems}
      currentUI={{ toc: currentUI.toc, series: currentUI.series }}
      {hasToc}
      {hasSeries}
    />
    <TOCDesktop
      {filteredHeadings}
      seriesItems={seriesItems}
      currentUI={{ toc: currentUI.toc, series: currentUI.series }}
      {hasToc}
      {hasSeries}
    />
  </>
)}
